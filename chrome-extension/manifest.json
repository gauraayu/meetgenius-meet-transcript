{
  "manifest_version": 3,
  "name": "GOG OMS — Meet Caption Bot",
  "version": "1.0.0",
  "description": "Automatically captures Google Meet captions (with speaker names) and sends them to GOG OMS for transcription and AI reports.",

  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "GOG OMS Caption Bot"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
